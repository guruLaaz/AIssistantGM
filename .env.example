# Fantrax CLI Configuration
# Copy this file to .env and fill in your actual credentials

# Required: Fantrax account credentials
FANTRAX_USERNAME=your_email@example.com
FANTRAX_PASSWORD=your_password

# Required: Your league ID
FANTRAX_LEAGUE_ID=your_league_id

# Optional: Custom cookie file name (default: fantraxloggedin.cookie)
# FANTRAX_COOKIE_FILE=fantraxloggedin.cookie

# Optional: Minimum seconds between API requests (default: 1.0)
# FANTRAX_MIN_REQUEST_INTERVAL=1.0

# Optional: Custom SQLite database path for caching (default: platform-specific data dir)
# Default locations:
#   Windows: C:\Users\<user>\AppData\Local\fantrax-cli\fantrax.db
#   macOS: ~/Library/Application Support/fantrax-cli/fantrax.db
#   Linux: ~/.local/share/fantrax-cli/fantrax.db
# FANTRAX_DB_PATH=/path/to/custom/fantrax.db
